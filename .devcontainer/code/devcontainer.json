{
	"name": "infrastructure-and-cluster-notebook",
	"build": {
		"dockerfile": "../Dockerfile",
		"context": "..",
		"target": "code"
	},
	"postCreateCommand": "npm ci",
	"forwardPorts": [4321],
	"portsAttributes": {
		"4321": {
			"label": "Astro dev server",
			"onAutoForward": "notify"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": ["astro-build.astro-vscode"]
		}
	}
}
